    <script src="/modern/assets/js/main.js" defer></script>

        <script>
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function (e) {
                e.preventDefault();
                showToast("Link berhasil disalin!");
            }, function (err) {
                console.error(err);
            });
        }
        function showToast(message) {
            const toast = document.getElementById("toast");
            toast.textContent = message;
            toast.style.visibility = "visible";
            toast.style.opacity = "1";

            setTimeout(() => {
                toast.style.opacity = "0";
                toast.style.visibility = "hidden";
            }, 2500);
        }

        function setParam(param, resetPage = ''){
            var params = new URLSearchParams(location.search);

            params.set(param.name, param.value);

            if (resetPage) {
                params.delete(resetPage);
            }

            window.location.href = location.pathname + '?' + params.toString();
        }

        function removeParam(paramName) {
            let url = new URL(window.location.href);
            url.searchParams.delete(paramName);
            window.history.replaceState({}, document.title, url.pathname + url.search);
            window.location.reload(true);
        }

        function renderPollingResult(polling, currentUser) {
            let totalVotes = 0;

            polling.options.forEach(opt => {
                totalVotes += opt.vote_count || 0;
            });
            let html = 
            `
                <div class="pic">
                    <a href="${polling.url}">
                        <img src="${polling.thumbnail}" alt="">
                    </a>
                </div>
            `
            html += `<div class="text">`;

            html += `
                <h3>${polling.post.title}</h3>
                <div class="flex justify-between">
                    <span class="text-[11px]">
                        <strong>${totalVotes.toLocaleString()}</strong> Voters
                    </span>
                </div>
                <p>${polling.question}</p>
            `;

            html += `<div class="flex flex-col gap-2">`;

            polling.options.forEach(opt => {
                let percent = totalVotes > 0
                    ? ((opt.vote_count / totalVotes) * 100).toFixed(2)
                    : 0;

                let userVotedThis = opt.votes?.some(v => v.username === currentUser);

                html += `
                    <div class="inp-group ${userVotedThis ? 'selected' : ''}">
                        <div class="progress-bar bg-bar" style="width:${percent}%;"></div>
                        <div class="flex gap-2 items-center z-10">
                            <span>${opt.option_text}</span>
                        </div>
                        ${currentUser ? `<span>${percent}%</span>` : ``}
                    </div>
                `;
            });

            html += `</div></div>`;

            return html;
        }





        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".pop-banner").forEach(function (banner) {
                const hasFloating = banner.querySelector(".floating-banner");
                const hasSticky   = banner.querySelector(".sticky-bottom-banner");

                if (banner.classList.contains("fl-banner") && !hasFloating) {
                    const closeBt = banner.querySelector(".close-bt");
                    if (closeBt) closeBt.style.display = "none";
                }

                if (banner.classList.contains("sbb") && !hasSticky) {
                    const closeBt = banner.querySelector(".close-bt");
                    if (closeBt) closeBt.style.display = "none";
                }
            });
        });

    </script>

    <script defer src="https://static.cloudflareinsights.com/beacon.min.js/v833ccba57c9e4d2798f2e76cebdd09a11778172276447" integrity="sha512-57MDmcccJXYtNnH+ZiBwzC4jb2rvgVCEokYN+L/nLlmO8rfYT/gIpW2A569iJ/3b+0UEasghjuZH/ma3wIs/EQ==" data-cf-beacon='{"version":"2024.11.0","token":"10fee8427bbe41ce84b1e750aba9c36b","server_timing":{"name":{"cfCacheStatus":true,"cfEdge":true,"cfExtPri":true,"cfL4":true,"cfOrigin":true,"cfSpeedBrain":true},"location_startswith":null}}' crossorigin="anonymous"></script>
</body>
</html>